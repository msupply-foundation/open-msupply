{
  "reports": [
    {
      "id": "item-list_2_17_0_false",
      "name": "Item List",
      "description": null,
      "template": {
        "index": {
          "template": "template.typ",
          "header": null,
          "footer": null,
          "query": [
            "query.graphql"
          ],
          "convert_data": "",
          "convert_data_type": "BoaJs",
          "template_type": "Typst"
        },
        "entries": {
          "template.typ": {
            "type": "TypstTemplate",
            "data": {
              "template": "// Test data — replaced with real data at report generation time\n#let report_data = (\n  data: (\n    items: (\n      nodes: (\n        (code: \"ABC001\", name: \"Acetylsalicylic Acid 100mg tabs\", locationName: \"Shelf A1\", SOH: 1250.0, categoryName: \"Analgesics\"),\n        (code: \"IBU200\", name: \"Ibuprofen 200mg tablets\", locationName: \"Shelf A2\", SOH: 830.0, categoryName: \"Analgesics\"),\n        (code: \"PAR500\", name: \"Paracetamol 500mg tablets\", locationName: \"Shelf A3\", SOH: 0.0, categoryName: \"Analgesics\"),\n        (code: \"AMX250\", name: \"Amoxicillin 250mg capsules\", locationName: \"Shelf B1\", SOH: 450.0, categoryName: \"Antibiotics\"),\n        (code: \"MET500\", name: \"Metformin 500mg tablets\", locationName: \"Shelf C1\", SOH: 2100.0, categoryName: \"Antidiabetics\"),\n        (code: \"ORS001\", name: \"Oral Rehydration Salts\", locationName: \"\", SOH: 340.0, categoryName: \"Electrolytes\"),\n      ),\n    ),\n  ),\n)\n\n#set page(\n  paper: \"a4\",\n  margin: (top: 2.5cm, bottom: 2cm, left: 1.5cm, right: 1.5cm),\n  header: context {\n    if counter(page).get().first() > 1 [\n      #set text(8pt, fill: rgb(\"#888\"))\n      Item List Report\n      #h(1fr)\n      #datetime.today().display(\"[day] [month repr:long] [year]\")\n    ]\n  },\n  footer: [\n    #set text(8pt, fill: rgb(\"#888\"))\n    #h(1fr)\n    Page #context counter(page).display(\"1 / 1\", both: true)\n    #h(1fr)\n  ],\n)\n\n#set text(font: \"New Computer Modern\", size: 10pt, fill: rgb(\"#333\"))\n\n// --- Title block ---\n#v(0.5cm)\n#text(18pt, weight: \"bold\", fill: rgb(\"#e95420\"))[Item List]\n#v(0.2cm)\n#text(10pt, fill: rgb(\"#666\"))[\n  Report generated #datetime.today().display(\"[day] [month repr:long] [year]\")\n]\n#line(length: 100%, stroke: 0.5pt + rgb(\"#ddd\"))\n#v(0.3cm)\n\n// --- Data ---\n#let items = report_data.data.items.nodes\n\n#text(9pt, fill: rgb(\"#888\"))[\n  Showing *#items.len()* items\n]\n#v(0.3cm)\n\n// --- Table ---\n#set table(\n  stroke: none,\n  inset: (x: 8pt, y: 6pt),\n  align: left,\n)\n\n#table(\n  columns: (auto, 1fr, auto, auto, 1fr),\n  fill: (_, row) => if row == 0 { rgb(\"#f5f5f5\") } else if calc.odd(row) { rgb(\"#fafafa\") } else { white },\n\n  // Header row\n  table.cell(colspan: 1)[#text(weight: \"bold\", size: 9pt)[Code]],\n  table.cell(colspan: 1)[#text(weight: \"bold\", size: 9pt)[Item name]],\n  table.cell(colspan: 1)[#text(weight: \"bold\", size: 9pt)[Location]],\n  table.cell(colspan: 1)[#align(right)[#text(weight: \"bold\", size: 9pt)[SOH]]],\n  table.cell(colspan: 1)[#text(weight: \"bold\", size: 9pt)[Category]],\n\n  // Header separator\n  table.hline(stroke: 1.5pt + rgb(\"#e95420\")),\n\n  // Data rows\n  ..items.map(item => (\n    text(size: 9pt)[#item.code],\n    text(size: 9pt)[#item.name],\n    text(size: 9pt, fill: rgb(\"#666\"))[#item.locationName],\n    align(right, text(size: 9pt)[#str(calc.round(item.SOH, digits: 1))]),\n    text(size: 9pt, fill: rgb(\"#666\"))[#item.categoryName],\n  )).flatten(),\n)\n"
            }
          },
          "style.css": {
            "type": "Resource",
            "data": "@page {\n  margin: 0;\n  size: A4 portrait;\n}\n\n.paging {\n  width: 100%;\n}\n\n.container {\n  margin: auto;\n  padding: 10px;\n  font-size: 14px;\n  font-family: \"Helvetica Neue\", \"Helvetica\", Helvetica, Arial, sans-serif;\n  color: #555;\n}\n\n.container table {\n  width: 100%;\n  font-size: inherit;\n  font-family: inherit;\n  text-align: left;\n  margin-top: 10;\n  margin-bottom: 15;\n  border-collapse: separate;\n}\n\n.container table td {\n  padding: 10px;\n  vertical-align: top;\n  border-top: 1px solid rgb(164, 163, 163);\n}\n\n.container table tr:last-child td {\n  border-bottom: none;\n}\n\n.container > table > thead {\n  position: -webkit-sticky;\n  position: sticky;\n  top: 0;\n  background-color: #f1f1f1;\n}\n\n.container,\nbody,\n.container > table {\n  margin-top: 0px;\n  padding-top: 0px;\n}\n\n.container table tr.heading td {\n  font-weight: bold;\n  margin-bottom: 15px;\n}\n\n.container table td.status span {\n  padding: 2px;\n  border-radius: 10px;\n}\n"
          },
          "query.graphql": {
            "type": "GraphGLQuery",
            "data": {
              "query": "query ItemList(\n  $storeId: String!\n  $itemCode: String\n  $itemName: String\n  $masterListId: String\n  $isActive: Boolean\n) {\n  items(\n    storeId: $storeId\n    filter: {\n      code: { like: $itemCode }\n      name: { like: $itemName }\n      isVisibleOrOnHand: true\n      isActive: $isActive\n      type: { equalTo: STOCK }\n      masterListId: { equalTo: $masterListId }\n    }\n  ) {\n    ... on ItemConnector {\n      nodes {\n        id\n        code\n        name\n        venCategory\n        stats: stats(storeId: $storeId) {\n          stockOnHand\n        }\n        categories {\n          name\n        }\n        itemStoreProperties: itemStoreProperties(storeId: $storeId) {\n          defaultLocation {\n            code\n          }\n        }\n      }\n    }\n  }\n}\n",
              "variables": null
            }
          }
        }
      },
      "context": "REPORT",
      "sub_context": "StockAndItems",
      "argument_schema_id": "for_report_item-list_2_17_0_false",
      "comment": null,
      "is_custom": false,
      "version": "2.17.0",
