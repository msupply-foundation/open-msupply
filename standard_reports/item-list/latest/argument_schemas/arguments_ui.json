{
  "type": "VerticalLayout",
  "elements": [
    {
      "type": "Control",
      "scope": "#/properties/itemCode",
      "label": "T#report.item-code",
      "options": {
        "useDebounce": false
      }
    },
    {
      "type": "Control",
      "scope": "#/properties/itemName",
      "label": "T#report.item-name"
    },
    {
      "type": "MasterListSearch",
      "scope": "#/properties/masterListId",
      "label": "T#label.master-list"
    },
    {
      "type": "Control",
      "scope": "#/properties/isActive",
      "label": "T#report.include-inactive-items",
      "options": {
        "invert": true
      }
    },
    {
      "type": "Control",
      "scope": "#/properties/onlyOutOfStock",
      "label": "T#report.only-out-of-stock"
    },
    {
      "type": "Control",
      "scope": "#/properties/venCategory",
      "label": "T#report.ven-category",
      "options": {
        "show": [
          ["V", "T#report.ven-vital"],
          ["E", "T#report.ven-essential"],
          ["N", "T#report.ven-necessary"],
          ["V_OR_E", "T#report.ven-v-or-e"],
          ["V_E_N", "T#report.ven-v-e-n"],
          ["NONE", "T#report.ven-none"]
        ]
      }
    },
    {
      "type": "Control",
      "scope": "#/properties/sort",
      "label": "T#report.sort-by",
      "options": {
        "show": [
          ["name", "T#report.item-name"],
          ["code", "T#label.code"],
          ["SOH", "T#report.stock-on-hand"],
          ["locationName", "T#report.item-location"],
          ["categoryName", "T#label.category"]
        ]
      }
    },
    {
      "type": "SortToggle",
      "scope": "#/properties/dir",
      "label": "T#report.sort-direction"
    }
  ]
}
