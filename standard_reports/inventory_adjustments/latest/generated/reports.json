{
  "reports": [
    {
      "id": "inventory_adjustments_2_14_0_false",
      "name": "Inventory Adjustments",
      "template": {
        "index": {
          "template": "template.html",
          "header": "header.html",
          "footer": null,
          "query": [
            "query.graphql"
          ],
          "convert_data": "",
          "convert_data_type": "BoaJs"
        },
        "entries": {
          "query.graphql": {
            "type": "GraphQLQuery",
            "data": {
              "query": "query InventoryAdjustments(\n  $storeId: String!\n  $adjustmentDateFrom: DateTime\n  $adjustmentDateTo: DateTime\n) {\n  # Query inventory adjustment invoices\n  invoices(\n    storeId: $storeId\n    filter: {\n      type: { equalAny: [INVENTORY_ADDITION, INVENTORY_REDUCTION] }\n      verifiedDatetime: {\n        afterOrEqualTo: $adjustmentDateFrom\n        beforeOrEqualTo: $adjustmentDateTo\n      }\n    }\n  ) {\n    ... on InvoiceConnector {\n      nodes {\n        id\n        invoiceNumber\n        type\n        verifiedDatetime\n        lines {\n          ... on InvoiceLineConnector {\n            nodes {\n              id\n              itemCode\n              itemName\n              batch\n              expiryDate\n              numberOfPacks\n              packSize\n              location {\n                id\n                code\n                name\n              }\n              stockLine {\n                id\n              }\n              inventoryAdjustmentReason {\n                id\n                reason\n              }\n              item {\n                id\n                code\n                name\n                unitName\n                masterLists(storeId: $storeId) {\n                  id\n                  name\n                }\n              }\n            }\n          }\n        }\n      }\n    }\n  }\n  # Query finalised stocktakes that have inventory adjustments\n  stocktakes(\n    storeId: $storeId\n    filter: {\n      status: { equalTo: FINALISED }\n      finalisedDatetime: {\n        afterOrEqualTo: $adjustmentDateFrom\n        beforeOrEqualTo: $adjustmentDateTo\n      }\n    }\n  ) {\n    ... on StocktakeConnector {\n      nodes {\n        id\n        stocktakeNumber\n        finalisedDatetime\n        inventoryAdditionId\n        inventoryReductionId\n        lines {\n          ... on StocktakeLineConnector {\n            nodes {\n              id\n              snapshotNumberOfPacks\n              countedNumberOfPacks\n              stockLine {\n                id\n              }\n            }\n          }\n        }\n      }\n    }\n  }\n  store(id: $storeId) {\n    ... on StoreNode {\n      id\n      code\n      storeName\n      logo\n      name(storeId: $storeId) {\n        address1\n        address2\n        code\n        email\n        phone\n      }\n    }\n  }\n}\n",
              "variables": null
            }
          },
          "style.css": {
            "type": "Resource",
            "data": "@page {\n  margin: 0;\n  size: A4 landscape;\n}\n\n.paging {\n  width: 100%;\n}\n\n.container {\n  margin: auto;\n  padding: 10px;\n  font-size: 14px;\n  font-family: \"Helvetica Neue\", \"Helvetica\", Helvetica, Arial, sans-serif;\n  color: #000;\n}\n\n.container table {\n  width: 100%;\n}\n\n.container table td {\n  padding: 10px;\n  vertical-align: top;\n  border-top: 1px solid rgb(164, 163, 163);\n}\n\n.container table tr:last-child td {\n  border-bottom: none;\n}\n\n.container>table>thead {\n  position: -webkit-sticky;\n  position: sticky;\n  top: 0;\n  background-color: #f1f1f1;\n}\n\n.container,\nbody,\n.container>table {\n  margin-top: 0px;\n}\n\n.container table tr.heading td,\n.container table tr.heading th {\n  background: #eee;\n  border-bottom: 1px solid #ddd;\n  font-weight: bold;\n  color: #000;\n}\n\n.container table td.status span {\n  display: inline;\n  padding: 5px 10px;\n  border-radius: 4px;\n}\n\n/* Header styles */\n.header-container {\n  width: 100%;\n  padding: 10px;\n  font-family: \"Helvetica Neue\", \"Helvetica\", Helvetica, Arial, sans-serif;\n  font-size: 10pt;\n  color: #000;\n}\n\n.header-title {\n  font-size: 20pt;\n  font-weight: bold;\n  text-align: center;\n  margin-bottom: 10px;\n  color: #000;\n}\n\n.header-info {\n  display: flex;\n  justify-content: space-between;\n  padding: 5px 0;\n  border-bottom: 1px solid #ccc;\n}\n\n.header-info-left {\n  text-align: left;\n}\n\n.header-info-right {\n  text-align: right;\n}\n\n.header-label {\n  font-weight: bold;\n}"
          },
          "header.html": {
            "type": "TeraTemplate",
            "data": {
              "output": "Html",
              "template": "<style>\n\t{% include \"style.css\" %}</style>\n\n<div class=\"header-container\">\n\t<div class=\"header-title\">\n\t\t{{ t(k=\"report.inventory-adjustments\", f=\"Inventory Adjustments Report\") }}\n\t</div>\n\t<div class=\"header-info\">\n\t\t<div class=\"header-info-left\">\n\t\t\t<span class=\"header-label\">{{ t(k=\"label.store\", f=\"Store\") }}:</span>\n\t\t\t<span>{{ data.store.storeName }}</span>\n\t\t</div>\n\t\t<div class=\"header-info-right\">\n\t\t\t<span class=\"header-label\">{{ t(k=\"label.timeframe\", f=\"Timeframe\") }}:</span>\n\t\t\t{% if data.date.from and data.date.to %}\n\t\t\t\t<span>{{ data.date.from | date(format=\"%d/%m/%Y\") }}\n\t\t\t\t\t-\n\t\t\t\t\t{{ data.date.to | date(format=\"%d/%m/%Y\") }}</span>\n\t\t\t{% elif data.date.from %}\n\t\t\t\t<span>{{ t(k=\"label.from\", f=\"From\") }}\n\t\t\t\t\t{{ data.date.from | date(format=\"%d/%m/%Y\") }}</span>\n\t\t\t{% elif data.date.to %}\n\t\t\t\t<span>{{ t(k=\"label.to\", f=\"To\") }}\n\t\t\t\t\t{{ data.date.to | date(format=\"%d/%m/%Y\") }}</span>\n\t\t\t{% else %}\n\t\t\t\t<span>{{ t(k=\"label.all-dates\", f=\"All dates\") }}</span>\n\t\t\t{% endif %}\n\t\t</div>\n\t</div>\n</div>\n"
            }
          },
          "template.html": {
            "type": "TeraTemplate",
            "data": {
              "output": "Html",
              "template": "<style>\n\t{% include \"style.css\" %}</style>\n\n<div class=\"container\">\n\t<table>\n\t\t<thead>\n\t\t\t<tr class=\"heading\">\n\t\t\t\t<th>{{t(k=\"label.code\", f=\"Code\")}}</th>\n\t\t\t\t<th>{{t(k=\"report.item-name\", f=\"Item name\")}}</th>\n\t\t\t\t<th>{{t(k=\"label.batch\", f=\"Batch\")}}</th>\n\t\t\t\t<th>{{t(k=\"label.expiry\", f=\"Expiry\")}}</th>\n\t\t\t\t<th>{{t(k=\"label.location\", f=\"Location\")}}</th>\n\t\t\t\t<th>{{t(k=\"label.snapshot-num-of-packs\",f=\"Snapshot Packs\")}}</th>\n\t\t\t\t<th>{{t(k=\"label.counted-num-of-packs\",f=\"Counted Packs\")}}</th>\n\t\t\t\t<th>{{t(k=\"label.adjustments\",f=\"Adjustments\")}}</th>\n\t\t\t\t<th>{{t(k=\"label.reason\",f=\"Reason\")}}</th>\n\t\t\t</tr>\n\t\t</thead>\n\t\t<tbody>\n\t\t\t{% for line in data.lines %}\n\t\t\t\t<tr>\n\t\t\t\t\t<td>{{ line.item.code }}</td>\n\t\t\t\t\t<td>{{ line.item.name }}</td>\n\t\t\t\t\t<td>{{ line.batch | default(value='-') }}</td>\n\t\t\t\t\t<td>\n\t\t\t\t\t\t{% if line.expiryDate %}\n\t\t\t\t\t\t\t{{ line.expiryDate | date(format=\"%d/%m/%Y\") }}\n\t\t\t\t\t\t{% else %}\n\t\t\t\t\t\t\t-\n\t\t\t\t\t\t{% endif %}\n\t\t\t\t\t</td>\n\t\t\t\t\t<td>{{ line.location.code | default(value='-') }}</td>\n\t\t\t\t\t<td style=\"text-align: right\">{{ line.snapshotPacks | default(value='-') }}</td>\n\t\t\t\t\t<td style=\"text-align: right\">{{ line.countedPacks | default(value='-') }}</td>\n\t\t\t\t\t<td style=\"text-align: right\">{{ line.adjustmentPacks | round(precision=2) }}</td>\n\t\t\t\t\t<td>{{ line.inventoryAdjustmentReason.reason | default(value='') }}</td>\n\t\t\t\t</tr>\n\t\t\t{% endfor %}\n\t\t</tbody>\n\t</table>\n</div>\n"
            }
          }
        }
      },
      "context": "REPORT",
      "sub_context": "StockAndItems",
      "argument_schema_id": "for_report_inventory_adjustments_2_14_0_false",
