{
  "name": "openmsupply-client",
  "//": "Version is shared between client and remote server and is located in repo root package.json",
  "version": "0.0.0",
  "sideEffects": false,
  "private": true,
  "scripts": {
    "android:build:debug": "yarn build && yarn workspace @openmsupply-client/android build:debug",
    "android:build:release": "yarn build && yarn workspace @openmsupply-client/android build:release",
    "android:build:server": "yarn build && yarn workspace @openmsupply-client/android build:server",
    "android:run": "npx cap run android",
    "build": "yarn workspace @openmsupply-client/host build",
    "build-stats": "yarn workspace @openmsupply-client/host build-stats",
    "build-storybook": "storybook build",
    "compile-full": "yarn workspaces foreach -A --parallel --exclude open-msupply --exclude openmsupply-client --exclude @openmsupply-client/android --exclude standard_reports --exclude standard_forms run tsc",
    "electron:build": "yarn workspace @openmsupply-client/electron make",
    "electron:start": "yarn workspace @openmsupply-client/electron start",
    "electron:start-local": "ELECTRON_HOST=http://localhost:3003 yarn workspace @openmsupply-client/electron start",
    "eslint": "yarn workspaces foreach -A --parallel --exclude open-msupply --exclude openmsupply-client --exclude standard_reports --exclude standard_forms run eslint",
    "generate": "cd ../server && cargo run --bin remote_server_cli -- export-graphql-schema && cd ../client && yarn gql-codegen",
    "gql-codegen": "graphql-codegen --config codegen.yml",
    "i18n-missing": "i18n-unused display-missed",
    "i18n-unused-display": "i18n-unused display-unused",
    "i18n-unused-remove": "i18n-unused remove-unused",
    "lint-and-format": "yarn re-compile && yarn prettier || true && yarn eslint",
    "prettier": "prettier --check 'packages/*/src/**/*.{js,jsx,ts,tsx,json,css,scss,md}'",
    "re-compile": "tsc --project packages/host/tsconfig.json --noEmit",
    "serve": "yarn workspace @openmsupply-client/host serve",
    "start": "yarn start-local",
    "start-local": "yarn workspace @openmsupply-client/host start-local",
    "start-remote": "yarn workspace @openmsupply-client/host start-remote",
    "storybook": "storybook dev -p 6006",
    "test": "jest --config ./jest.config.js --maxWorkers=50% --env=jsdom --testPathIgnorePatterns codegen.test.ts --testPathIgnorePatterns playwright",
    "test:codegen": "jest --config ./jest.config.js codegen.test.ts",
    "translate": "node translate_locale"
  },
  "devDependencies": {
    "@babel/core": "^7.21.3",
    "@babel/preset-flow": "^7.21.4",
    "@chromatic-com/storybook": "^1.6.1",
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/near-operation-file-preset": "^3.0.0",
    "@graphql-codegen/typescript": "^4.0.1",
    "@graphql-codegen/typescript-graphql-request": "^6.2.0",
    "@graphql-codegen/typescript-operations": "^4.0.1",
    "@storybook/addon-actions": "^8.1.11",
    "@storybook/addon-essentials": "^8.1.11",
    "@storybook/addon-interactions": "^8.1.11",
    "@storybook/addon-links": "^8.1.11",
    "@storybook/addon-webpack5-compiler-swc": "^1.0.4",
    "@storybook/addons": "^7.0.4",
    "@storybook/react": "^8.1.11",
    "@storybook/react-webpack5": "^8.1.11",
    "@storybook/test": "^8.1.11",
    "@storybook/theming": "^8.1.11",
    "@swc/cli": "^0.4.0",
    "@swc/core": "^1.6.7",
    "@swc/jest": "^0.2.15",
    "@testing-library/dom": "^10.3.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.1.1",
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.14.178",
    "@types/node": "^20.14.9",
    "@types/papaparse": "^5.3.2",
    "@types/react": "^19.2.14",
    "@types/recharts": "^1.8.23",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "babel-jest": "^29.6.2",
    "babel-loader": "^9.1.2",
    "babel-preset-react-app": "^10.0.1",
    "eslint": "^8.50.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest-dom": "^5.0.1",
    "eslint-plugin-react": "^7.27.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-storybook": "^0.8.0",
    "i18n-unused": "0.19.0",
    "jest": "^29.6.2",
    "jest-environment-jsdom": "^29.6.2",
    "jest-transform-stub": "^2.0.0",
    "jetifier": "^2.0.0",
    "prettier": "^3.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^8.1.11",
    "storybook-addon-swc": "^1.1.7",
    "ts-jest": "^29.1.0",
    "tsconfig-paths-webpack-plugin": "^4.0.1",
    "typescript": "^5.0.2",
    "webpack": "^5.88.1",
    "yarn-outdated-formatter": "^4.0.0"
  },
  "dependencies": {
    "@bugsnag/js": "^7.25.0",
    "@capacitor/camera": "5",
    "@mui/x-date-pickers": "^8.5.1",
    "@types/react-dom": "^19.2.3",
    "graphql": "^16.3.0",
    "papaparse": "^5.3.2",
    "pluralize": "^8.0.0"
  }
}
