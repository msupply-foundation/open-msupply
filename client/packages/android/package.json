{
  "name": "@openmsupply-client/android",
  "version": "0.0.0",
  "private": true,
  "devDependencies": {
    "@bcyesil/capacitor-plugin-printer": "^0.0.4",
    "@capacitor-community/file-opener": "^6.0.1",
    "@capacitor-community/keep-awake": "^5.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/device": "^8.0.0",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/screen-orientation": "^8.0.0"
  },
  "scripts": {
    "build:server": "./build_remote_server_libs.sh",
    "//": "assembleDebug and assembleRelease will build both arm64 and universal flavors in client/packages/android/app/build.gradle",
    "build:debug": "yarn build:server && yarn apply-config:debug && ./gradlew assembleDebug",
    "build:release": "yarn build:server && yarn apply-config && ./gradlew assembleRelease",
    "apply-config:debug": "DEBUG_BUILD=true yarn apply-config",
    "apply-config": "npx cap copy"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^8.0.0",
    "@capacitor/android": "^8.0.0",
    "@capacitor/camera": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/geolocation": "^8.0.0"
  }
}
